# Database
DATABASE_URL=postgresql://hubify:your_password@localhost:5432/hubify_mail

# PostgreSQL connection pool (per process/worker). For high concurrency raise
# PG_POOL_MAX, and ensure PostgreSQL max_connections >= PM2_INSTANCES * PG_POOL_MAX.
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000

# Server
PORT=3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
MAIL_SERVER_HOSTNAME=mail.hubify.store

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this
INBOX_ACCESS_JWT_SECRET=another_long_random_secret_for_protected_inbox_tokens
INBOX_ACCESS_TOKEN_TTL=15m
INBOX_UNLOCK_MAX_ATTEMPTS=5
INBOX_UNLOCK_WINDOW_MS=60000
PUBLIC_RESERVATION_MAX_PER_IP=5
PUBLIC_RESERVATION_TTL_DAYS=7
INBOX_RESERVATION_IP_SALT=replace_with_a_long_random_secret

# Rate Limiting (public IP-based limit for /api/* public + admin routes)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Postfix sync (optional): when adding/updating/deleting domains from admin, update Postfix automatically
# Set to true and configure sudo (see docs/domain-guide.md) to enable
# POSTFIX_SYNC_ENABLED=false
# POSTFIX_DOMAINS_FILE= (default: backend/.postfix-domains)

# Email ingestion (Postfix pipe handler)
# Reject raw emails larger than this many bytes (default 1MB). Oversized mail
# is dropped gracefully so Postfix does not retry forever.
MAX_EMAIL_BYTES=1048576
# Max time (ms) to wait for Telegram/Discord notifications before the pipe
# process exits. Notifications are best-effort and never block email saving.
NOTIFY_TIMEOUT_MS=3000

# Inbox listing: default number of emails returned by list/polling endpoints.
# Detail content is still available via /email/:id.
INBOX_LIST_LIMIT=20

# External API (per-API-key limit, independent from the public IP limit)
# 5000 req/min is generous headroom for bulk OTP polling (e.g. 400 accounts
# polled every 5s ≈ 4800 req/min). Lower it if you expose the key publicly.
API_KEY=your_secret_api_key_here
API_RATE_LIMIT_MAX=5000

# PM2 cluster: number of workers ("max" for all CPU cores, or a number).
# NOTE: the Telegram long-polling bot runs only on worker instance 0.
PM2_INSTANCES=2

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_OWNER_ID=your_telegram_chat_id
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxx
